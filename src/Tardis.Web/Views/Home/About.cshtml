@{
    ViewData["Title"] = "About";
}
<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-8">
        <h2>Contact Information</h2>
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Get in Touch</h5>
                <p class="card-text">
                    <strong>Contact Name:</strong> Rob Foulkrod<br>
                    <strong>Phone:</strong> (313) 555-1212
                </p>
            </div>
        </div>

        <h2>Cool Facts About the TARDIS</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-box"></i> Bigger on the Inside</h5>
                        <p class="card-text">The TARDIS is dimensionally transcendental, meaning it's bigger on the inside than the outside due to advanced Time Lord technology.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-clock"></i> Time Travel</h5>
                        <p class="card-text">TARDIS stands for "Time And Relative Dimension In Space" - it can travel anywhere in time and space throughout the universe.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-telephone"></i> Police Box Disguise</h5>
                        <p class="card-text">The TARDIS is disguised as a 1960s British police box, though its chameleon circuit is broken and stuck in this form.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-heart"></i> Living Machine</h5>
                        <p class="card-text">The TARDIS is a living, sentient machine with its own personality, and it forms a telepathic bond with its pilot.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-shield-check"></i> Indestructible</h5>
                        <p class="card-text">The TARDIS is virtually indestructible and has survived the destruction of entire planets and the end of the universe itself.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-translate"></i> Universal Translation</h5>
                        <p class="card-text">The TARDIS can translate any language in the universe telepathically, allowing its occupants to communicate with anyone.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">TARDIS Console</h5>
                <div class="mb-3" style="font-size: 4rem; color: var(--bs-primary);">
                    <i class="bi bi-box"></i>
                </div>
                <p class="card-text">The central console contains six panels operated by the Doctor and companions to navigate through time and space.</p>
            </div>
        </div>
    </div>
</div>