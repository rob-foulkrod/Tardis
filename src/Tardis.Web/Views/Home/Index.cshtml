@{
    ViewData["Title"] = "TARDIS — Home";
}

<div class="hero-section">
    <div class="container text-center">
        <div class="logo-container">
            <img src="~/project_tardis_logo.png" alt="TARDIS Logo" class="logo-img" onerror="this.style.display='none'" />
        </div>
        <h1 class="main-title">Welcome to TARDIS</h1>
        <p class="subtitle">Time And Relative Dimension In Space — your gateway to infinite possibilities.</p>
        <a class="cta-button" href="@Url.Action("Privacy", "Home")">Start Your Journey</a>
    </div>

    <svg class="position-absolute top-0 start-0 w-100 h-100" preserveAspectRatio="none" viewBox="0 0 100 100" aria-hidden="true" focusable="false" style="pointer-events:none; opacity:.05">
        <defs>
            <linearGradient id="grad" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0%" stop-color="var(--tardis-teal)" />
                <stop offset="100%" stop-color="var(--tardis-purple)" />
            </linearGradient>
        </defs>
        <circle cx="15" cy="20" r="14" fill="url(#grad)" />
        <circle cx="90" cy="10" r="10" fill="url(#grad)" />
        <circle cx="70" cy="85" r="20" fill="url(#grad)" />
    </svg>

    <div class="features-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon"><i class="bi bi-rocket-takeoff"></i></div>
                        <h3 class="feature-title">Fast & Reliable</h3>
                        <p class="feature-description">Experience lightning-fast performance powered by ASP.NET Core.</p>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                        <h3 class="feature-title">Secure</h3>
                        <p class="feature-description">Built with security in mind, protecting data across time and space.</p>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon"><i class="bi bi-infinity"></i></div>
                        <h3 class="feature-title">Scalable</h3>
                        <p class="feature-description">Grow without limits. Our platform scales with your needs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
